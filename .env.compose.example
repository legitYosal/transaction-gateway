# Gateway PostgreSQL
GATEWAY_POSTGRES_DB=gateway
GATEWAY_POSTGRES_USER=gateway
GATEWAY_POSTGRES_PASSWORD=gateway
GATEWAY_POSTGRES_HOST_PORT=5433

# Gateway app
GATEWAY_API_HOST_PORT=8000

# Inside Docker Compose, use postgres-gateway:5432, not localhost:5433
export GATEWAY_DATABASE_URL=postgresql+psycopg://gateway:gateway@postgres-gateway:5432/gateway

# For now this points to host machine ledger service.
# On Mac/Windows Docker Desktop, host.docker.internal works.
# Later, when ledger service is in compose, change this to:
# http://ledger-service:8000
export GATEWAY_LEDGER_SERVICE_URL=http://host.docker.internal:8001
